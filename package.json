{
  "name": "blog",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "audit": "pnpm audit --audit-level=high",
    "deps:check": "pnpm -r outdated",
    "deps:update": "pnpm -r update && pnpm build",
    "deps:update:major": "pnpm -r up -iL",
    "type": "tsc --noEmit",
    "lint": "eslint . --max-warnings 10",
    "prebuild": "next typegen && pnpm run type && pnpm run lint",
    "build": " next build",
    "start": "next start",
    "prettier": "prettier --write './**/*.tsx'"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "dayjs": "^1.11.21",
    "fuse.js": "^7.4.2",
    "gray-matter": "^4.0.3",
    "js-cookie": "^3.0.8",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.11",
    "openai": "^6.42.0",
    "query-string": "^9.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tiny-invariant": "^1.3.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
